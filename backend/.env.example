POSTGRES_USER=playback
POSTGRES_PASSWORD=playback
POSTGRES_DB=playback

DATABASE_URL=postgresql://playback:playback@localhost:5433/playback
REDIS_URL=redis://localhost:6379/0
GROQ_API_KEY=your-groq-api-key-here
CORS_ORIGIN=http://localhost:5173

# Optional — defaults as shown. Both transcription and notes/quiz generation run through
# Groq's API, so no local model download or CPU/RAM sizing is needed.
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# Optional — both default as shown. Swapping models/providers (e.g. a different Groq model,
# or another provider LangChain supports) is a config change here, not a code change.
# llama-3.3-70b-versatile supports tool-calling, which structured note/quiz generation relies on.
LLM_PROVIDER=groq
LLM_MODEL_NAME=llama-3.3-70b-versatile

# Optional, unset by default — only needed on hosts where YouTube blocks the request with
# "Sign in to confirm you're not a bot" (common on cloud/datacenter IPs, e.g. Railway/Render;
# rarely needed for local dev on a residential IP). Paste the full contents of a Netscape-format
# cookies.txt exported from a logged-in YouTube session (e.g. via the "Get cookies.txt LOCALLY"
# browser extension). See backend/README.md for the full how-to.
# YT_DLP_COOKIES=

# Optional, unset by default — if cookies alone aren't enough to pass YouTube's bot-check
# (confirmed on Railway: cookies reached the process correctly but were still rejected), run
# a bgutil-ytdlp-pot-provider server (https://github.com/Brainicism/bgutil-ytdlp-pot-provider)
# as its own service and point this at it, e.g. http://127.0.0.1:4416 locally or an internal
# service URL on your host. See backend/README.md for the full how-to.
# POT_PROVIDER_BASE_URL=

POSTGRES_USER=playback
POSTGRES_PASSWORD=playback
POSTGRES_DB=playback

DATABASE_URL=postgresql://playback:playback@localhost:5433/playback
REDIS_URL=redis://localhost:6379/0
GROQ_API_KEY=your-groq-api-key-here
CORS_ORIGIN=http://localhost:5173

# Optional — defaults as shown. Both transcription and notes/quiz generation run through
# Groq's API, so no local model download or CPU/RAM sizing is needed.
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# Optional — both default as shown. Swapping models/providers (e.g. a different Groq model,
# or another provider LangChain supports) is a config change here, not a code change.
# llama-3.3-70b-versatile supports tool-calling, which structured note/quiz generation relies on.
LLM_PROVIDER=groq
LLM_MODEL_NAME=llama-3.3-70b-versatile

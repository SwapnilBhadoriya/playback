POSTGRES_USER=playback
POSTGRES_PASSWORD=playback
POSTGRES_DB=playback

DATABASE_URL=postgresql://playback:playback@localhost:5433/playback
REDIS_URL=redis://localhost:6379/0
GOOGLE_API_KEY=your-google-api-key-here
CORS_ORIGIN=http://localhost:5173

# Optional — defaults to "base" if unset. Larger sizes (small/medium/large-v3) are more
# accurate but slower on CPU.
WHISPER_MODEL_SIZE=base

# Optional — both default as shown. Swapping models/providers (e.g. a different Gemini
# version, or another provider LangChain supports) is a config change here, not a code change.
# Dated model names (e.g. gemini-2.5-flash) can become unavailable to newer API keys/projects
# even while still listed by the API — gemini-flash-latest is Google's rolling alias to the
# current recommended flash model, which avoids that trap.
LLM_PROVIDER=google_genai
LLM_MODEL_NAME=gemini-flash-latest
